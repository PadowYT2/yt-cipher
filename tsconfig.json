{
    "extends": "@tsconfig/strictest",
    "compilerOptions": {
        "module": "ESNext",
        "target": "ESNext",
        "moduleResolution": "Bundler",
        "rootDir": "./",
        "noEmit": true,
        "noPropertyAccessFromIndexSignature": false,
        "outDir": "./dist",
        "paths": {
            "@/*": ["./src/*"]
        },
        "types": ["bun"]
    },
    "include": ["./src/**/*", "./*.ts"]
}
